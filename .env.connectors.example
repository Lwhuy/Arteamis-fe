# Connectors E2E — copy the vars you need into your real `.env` (same directory).
# REQUIRED for connectors (token storage fails without it):
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-any-non-empty-string

# OAuth redirect origins (dev-local)
CONNECTORS_API_URL=http://localhost:5055
CONNECTORS_APP_URL=http://localhost:3000

# Google Drive (register at console.cloud.google.com — see docs/connectors-oauth-setup.md)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

# Slack (api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion (notion.so/my-integrations, Public integration)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# NOTE: you also need your normal app config here (AI provider keys, DB settings, etc.).
# If auth is on, JWT_SECRET must be set; the connectors OAuth callback bypasses it by design.
